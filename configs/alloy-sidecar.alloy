// ─────────────────────────────────────────────────────────
// Grafana Alloy Sidecar Config (Layer 2 — 앱 관측)
//
// 데이터 흐름:
//   앱 → localhost:4317 (OTLP gRPC) → Alloy → Grafana Cloud
//
// 환경변수:
//   ALLOY_SERVICE_NAME         — "backend" | "ai-server"
//   ALLOY_DEPLOY_ENV           — "dev" | "prod"
//   ALLOY_SAMPLING_RATE        — "10" (dev) | "100" (prod)
//   GRAFANA_OTLP_ENDPOINT      — https://otlp-gateway-...grafana.net/otlp
//   GRAFANA_CLOUD_INSTANCE_ID  — Grafana Cloud stack instance id
//   GRAFANA_CLOUD_TOKEN        — API token
//
// ⌁ PII Redaction
// 외부(Grafana Cloud) 로 데이터 보내기 전에 redaction processor 가
// 알려진 PII 속성을 제거하거나 해싱합니다. 코드에서 실수로 PII 가
// span attribute / log field 에 들어가도 외부로 안 새도록 하는 안전망.

// ── OTLP Receiver — 앱이 localhost:4317 로 전송 ──────────
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces  = [otelcol.processor.resourcedetection.default.input]
    metrics = [otelcol.processor.resourcedetection.default.input]
    logs    = [otelcol.processor.resourcedetection.default.input]
  }
}

// ── Resource Detection (ECS 메타데이터 자동 추출) ────────
otelcol.processor.resourcedetection "default" {
  detectors = ["env", "ecs"]

  output {
    traces  = [otelcol.processor.attributes.default.input]
    metrics = [otelcol.processor.attributes.default.input]
    logs    = [otelcol.processor.attributes.default.input]
  }
}

// ── Resource Attributes 표준화 ───────────────────────────
otelcol.processor.attributes "default" {
  action {
    key    = "service.name"
    value  = env("ALLOY_SERVICE_NAME")
    action = "upsert"
  }
  action {
    key    = "service.namespace"
    value  = "drawe"
    action = "upsert"
  }
  action {
    key    = "deployment.environment"
    value  = env("ALLOY_DEPLOY_ENV")
    action = "upsert"
  }

  output {
    traces  = [otelcol.processor.attributes.redact.input]
    metrics = [otelcol.processor.batch.default.input]
    logs    = [otelcol.processor.attributes.redact.input]
  }
}

// ── PII Redaction — trace / log 한정 ─────────────────────
otelcol.processor.attributes "redact" {
  // 1) 직접 식별 가능한 PII → 삭제
  action {
  key    = "user.email"
  action = "delete"
}
  action {
  key    = "user.name"
  action = "delete"
}
  action {
  key    = "user.phone"
  action = "delete"
}
  action {
  key    = "end_user.id"
  action = "delete"
}
  action {
  key    = "enduser.id"
  action = "delete"
}
  action {
  key    = "client_address"
  action = "delete"
}
  action {
  key    = "net.peer.ip"
  action = "delete"
}
  action {
  key    = "client.address"
  action = "delete"
}

  // 2) 사용자 ID 는 해시 (디버깅용 상관관계 유지)
  action {
  key    = "user.id"
  action = "hash"
}
  action {
  key    = "session.id"
  action = "hash"
}

  // 3) 요청/응답 본문 통째로 → 삭제
  action {
  key    = "http.request.body"
  action = "delete"
}
  action {
  key    = "http.response.body"
  action = "delete"
}

  // 4) 헤더 (auth/cookie 포함 가능) → 삭제
  action {
    pattern = "^http\\.(request|response)\\.header\\..*$"
    action  = "delete"
  }

  // 5) DB statement (parameter 박힐 위험) → 삭제
  // (db.system, db.operation 같은 메타정보는 다른 키라 안전)
  action {
  key    = "db.statement"
  action = "delete"
}

  // 6) Exception 메시지 (입력값 노출 위험) → 메시지만 삭제, 타입/스택은 유지
  action {
  key    = "exception.message"
  action = "delete"
}

  // 7) URL 의 query string → 삭제 (path 는 유지)
  // http.url 자체를 hash 하면 path 도 안 보임. query 만 잘라낼 처리는
  // 별도 transformprocessor 가 필요. 보수적으로 url 자체를 hash.
  action {
  key    = "http.url"
  action = "hash"
}
  action {
  key    = "url.full"
  action = "hash"
}
  action {
  key    = "url.query"
  action = "delete"
}

  // 8) LLM prompt / completion 본문 → 삭제
  // 사용자 입력이 그대로 들어가는 곳. metadata (model, token count) 는 유지
  action {
  key    = "gen_ai.prompt"
  action = "delete"
}
  action {
  key    = "gen_ai.completion"
  action = "delete"
}
  action {
  key    = "llm.prompts"
  action = "delete"
}
  action {
  key    = "llm.completions"
  action = "delete"
}

  // 9) JWT, API key 같은 토큰 (실수로 attribute 박힐 경우)
  action {
  key    = "auth.token"
  action = "delete"
}
  action {
  key    = "api.key"
  action = "delete"
}
  action {
  key    = "authorization"
  action = "delete"
}

  output {
    traces = [otelcol.processor.probabilistic_sampler.default.input]
    logs   = [otelcol.processor.batch.default.input]
  }
}

// ── Trace Sampling (dev: 10%, prod: 100%) ───────────────
otelcol.processor.probabilistic_sampler "default" {
  sampling_percentage = env("ALLOY_SAMPLING_RATE")

  output {
    traces = [otelcol.processor.batch.default.input]
  }
}

// ── Batch ────────────────────────────────────────────────
otelcol.processor.batch "default" {
  timeout         = "5s"
  send_batch_size = 512

  output {
    traces  = [otelcol.exporter.otlphttp.grafana_cloud.input]
    metrics = [otelcol.exporter.otlphttp.grafana_cloud.input]
    logs    = [otelcol.exporter.otlphttp.grafana_cloud.input]
  }
}

// ── Grafana Cloud OTLP 인증 ──────────────────────────────
otelcol.auth.basic "grafana_cloud" {
  username = env("GRAFANA_CLOUD_INSTANCE_ID")
  password = env("GRAFANA_CLOUD_TOKEN")
}

// ── Export → Grafana Cloud ───────────────────────────────
otelcol.exporter.otlphttp "grafana_cloud" {
  client {
    endpoint = env("GRAFANA_OTLP_ENDPOINT")
    auth     = otelcol.auth.basic.grafana_cloud.handler
  }
}
