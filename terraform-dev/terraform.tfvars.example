############################################################
# DraWe dev — terraform.tfvars
############################################################

# ── 필수 ─────────────────────────────────────────────────
key_pair_name = "drawe-dev-keypair"

# ── PART A 단계 (HTTP-only, 인프라만 띄울 때) ─────────────
# domain_name 을 빈 문자열로 두면 HTTPS 안 켜짐 — ALB DNS 로 health check 만 가능.
# OAuth 로그인은 이 상태에서 동작하지 않음 (HTTPS 필수).
#
# domain_name        = ""
# frontend_url       = "https://dev.drawe.pages.dev"
# cloudflare_zone_id = ""

# ── PART B 단계 (도메인 + HTTPS + OAuth 활성화) ───────────
# 아래 3개를 모두 채우면 ACM 인증서 자동 발급 + Cloudflare DNS 자동 등록
domain_name        = "api-dev.drawe.xyz"
frontend_url       = "https://dev.drawe.xyz"
cloudflare_zone_id = "your-zone-id-from-cloudflare-overview"

# Cloudflare API token 은 환경변수 권장 (commit 위험 회피):
#   export CLOUDFLARE_API_TOKEN="..."
# 또는 여기에 직접 (.gitignore 확인 필수):
# cloudflare_api_token = "..."

# ── Cloudflare proxy 모드 ────────────────────────────────
# dev 권장: false (DNS only, gray cloud) — CORS / cache 디버깅 단순.
# prod 처럼 proxied 모드 검증하려면 true 로:
# cloudflare_proxied = false

# ── 비용 절감 schedule ───────────────────────────────────
# 평일 13~18 KST 만 운영. 그 외 시간 NAT/RDS/Valkey/ECS 모두 stop.
enable_cost_schedule = true

# ── GitHub Actions OIDC ───────────────────────────────────
# CI/CD 자동 배포용. 비워두면 OIDC role 미생성 (수동 배포만 가능).
# prod terraform-prod 는 dev 가 만든 OIDC provider 를 data source 로 참조.
github_owner = "hyegyeongseo"
# github_repos default: ["drawe-backend", "drawe-fastapi"] — variables.tf 참고

# ── 비밀번호 직접 지정 (선택) ─────────────────────────────
# 비워두면 32자 random 자동 생성 (권장).
# 본인 지정 시 환경변수로:
#   export TF_VAR_db_password='your-strong-db-password'
#   export TF_VAR_valkey_password='your-valkey-pass'
