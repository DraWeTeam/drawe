# Server
SERVER_PORT=8080

# Database
DB_PORT=3306
DB_USERNAME=user
DB_PASSWORD=change-me-user
MYSQL_ROOT_PASSWORD=change-me-root

# Redis (Valkey)
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
LOG_LEVEL_SQL=debug

# JWT
JWT_SECRET=please-replace-with-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# CORS (로컬: localhost:5173, AWS: 가비아 도메인)
APP_CORS_ALLOWED_ORIGINS=https://drawe.xyz,https://www.drawe.xyz,http://localhost:5173,https://drawe-frontend.pages.dev

# Domain — Caddy가 이 도메인으로 인증서 발급
DOMAIN_NAME=api.drawe.xyz

# LLM API Keys
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GROK_API_KEY=YOUR_GROK_API_KEY
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY
BRIA_API_KEY=YOUR_BRIA_API_KEY

# Optional overrides
# LLM_DEFAULT_PROVIDER=gemini

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
#APP_OAUTH2_REDIRECT_URI=https://drawe.xyz/oauth/callback
APP_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback
 
# PINECONE
PINECONE_API_KEY = YOUR_PINECONE_API_KEY
PINECONE_HOST = https://drawe-images-l2eyvny.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX = drawe-images

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=my-secret-password

# google Gmail SMTP 이메일 전송
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=change_smpt_name
SMTP_PASSWORD=change_smpt_password

# 사용자 피드백 팀 메일 알림 (DB가 원본, 메일은 알림 채널)
# enabled=false(기본)면 발송 스킵. 켜려면 FEEDBACK_MAIL_TO(팀 공용 메일함)를 채울 것.
# SMTP 접속 정보는 위 SMTP_* 를 공용으로 사용. FROM 비우면 SMTP_USERNAME 으로 발송.
FEEDBACK_MAIL_ENABLED=false
FEEDBACK_MAIL_TO=drawe-feedback@example.com
FEEDBACK_MAIL_FROM=

# Workflow COMPOSE live (AI 파이프라인 전환)
# 나열된 의도를 레거시 직접합성 대신 COMPOSE 워크플로로 처리. 비우면 전부 레거시(OFF).
# COMPOSE 로 끝나는 의도만 허용(부팅 시 검증, 아니면 기동 실패).
WORKFLOW_COMPOSE_LIVE_INTENTS=NEW_SEARCH,KEEP,SKIP,COMPOSITION,LIGHTING,COLOR,TECHNIQUE,FOLLOWUP,COMPARE,OUT_OF_DOMAIN,SELF_CRITIQUE
