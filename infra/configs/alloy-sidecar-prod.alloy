// ─────────────────────────────────────────────────────────
// Grafana Alloy Sidecar Config — prod (self-host LGT + AMP)
//
// 데이터 흐름:
//   앱 → localhost:4317 (OTLP gRPC) → Alloy →
//     metrics → AMP (SigV4)
//     logs    → Loki (loki.${prefix}.local:3100)
//     traces  → Tempo (tempo.${prefix}.local:4317)
//
// 환경변수:
//   ALLOY_SERVICE_NAME           — "backend" | "ai-server"
//   ALLOY_DEPLOY_ENV             — "prod"
//   ALLOY_SAMPLING_RATE          — "10" (prod 설정값, AMP/Tempo cost 통제)
//   AMP_REMOTE_WRITE_URL         — https://aps-workspaces.<region>.amazonaws.com/.../api/v1/remote_write
//   AWS_REGION                   — ap-northeast-2
//   LOKI_URL                     — http://loki.drawe-prod.local:3100
//   TEMPO_OTLP_ENDPOINT          — tempo.drawe-prod.local:4317
//
// PII redaction 은 alloy-sidecar.alloy(dev) 와 동일 — 같은 redaction 룰 적용
// ─────────────────────────────────────────────────────────

// ── 앱 메트릭 스크레이프 (backend /actuator/prometheus) ──
// 같은 ECS task 라 localhost 로 앱을 긁는다. backend task(8080)에서만 유효.
// fastapi task 엔 actuator 가 없어 up=0 (무해). 제거하려면 sidecar config 를 서비스별로 분리.
prometheus.scrape "app" {
  targets = [{
    __address__      = "localhost:8080",
    __metrics_path__ = "/actuator/prometheus",
  }]
  forward_to      = [otelcol.receiver.prometheus.app.receiver]
  scrape_interval = "30s"
  job_name        = "backend-actuator"
}

otelcol.receiver.prometheus "app" {
  output {
    metrics = [otelcol.processor.attributes.default.input]
  }
}

// ── OTLP Receiver ─────────────────────────────────────────
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces  = [otelcol.processor.resourcedetection.default.input]
    metrics = [otelcol.processor.resourcedetection.default.input]
    logs    = [otelcol.processor.resourcedetection.default.input]
  }
}

// ── Resource Detection (ECS 메타데이터) ─────────────────
otelcol.processor.resourcedetection "default" {
  detectors = ["env", "ecs"]

  output {
    traces  = [otelcol.processor.attributes.default.input]
    metrics = [otelcol.processor.attributes.default.input]
    logs    = [otelcol.processor.attributes.default.input]
  }
}

// ── Resource Attributes 표준화 ───────────────────────────
otelcol.processor.attributes "default" {
  action {
    key    = "service.name"
    value  = env("ALLOY_SERVICE_NAME")
    action = "upsert"
  }
  action {
    key    = "service.namespace"
    value  = "drawe"
    action = "upsert"
  }
  action {
    key    = "deployment.environment"
    value  = env("ALLOY_DEPLOY_ENV")
    action = "upsert"
  }

  output {
    traces  = [
      otelcol.processor.attributes.redact.input,
      otelcol.connector.spanmetrics.default.input,
    ]
    metrics = [otelcol.processor.batch.metrics.input]
    logs    = [otelcol.processor.attributes.redact.input]
  }
}

// ── PII Redaction (trace + log) ──────────────────────────
otelcol.processor.attributes "redact" {
  action { key = "user.email"
    action = "delete" }
  action { key = "user.name"
    action = "delete" }
  action { key = "user.phone"
    action = "delete" }
  action { key = "end_user.id"
    action = "delete" }
  action { key = "enduser.id"
    action = "delete" }
  action { key = "client_address"
    action = "delete" }
  action { key = "net.peer.ip"
    action = "delete" }
  action { key = "client.address"
    action = "delete" }

  // 식별자는 앱(OtelCorrelationFilter)이 이미 가공: user.id 는 1회 해시, session.id 는 opaque.
  // 수집기에서 재해시하지 않는다 — 재해시하면 로그(daemon 경로, 재해시 안 됨)와 값이 달라져
  // admin 딥링크·log↔trace 조인이 prod 에서 깨진다. dev sidecar 와 동일하게 pass-through.

  action { key = "http.request.body"
    action = "delete" }
  action { key = "http.response.body"
    action = "delete" }

  action {
    pattern = "^http\\.(request|response)\\.header\\..*$"
    action  = "delete"
  }

  action { key = "db.statement"
    action = "delete" }
  action { key = "exception.message"
    action = "delete" }

  action { key = "http.url"
    action = "hash" }
  action { key = "url.full"
    action = "hash" }
  action { key = "url.query"
    action = "delete" }

  action { key = "gen_ai.prompt"
    action = "delete" }
  action { key = "gen_ai.completion"
    action = "delete" }
  action { key = "llm.prompts"
    action = "delete" }
  action { key = "llm.completions"
    action = "delete" }

  action { key = "auth.token"
    action = "delete" }
  action { key = "api.key"
    action = "delete" }
  action { key = "authorization"
    action = "delete" }

  output {
    traces = [otelcol.processor.probabilistic_sampler.default.input]
    logs   = [otelcol.processor.batch.logs.input]
  }
}

// ── Trace Sampling ──────────────────────────────────────
otelcol.processor.probabilistic_sampler "default" {
  sampling_percentage = env("ALLOY_SAMPLING_RATE")

  output {
    traces = [otelcol.processor.batch.traces.input]
  }
}

otelcol.connector.spanmetrics "default" {
  histogram {
    explicit {
      buckets = ["5ms", "10ms", "25ms", "50ms", "100ms", "250ms", "500ms",
                 "1s", "2.5s", "5s", "10s"]
    }
  }

  dimension { name = "http.method" }
  dimension { name = "http.status_code" }
  dimension { name = "http.route" }

  namespace = "traces.spanmetrics"

  output {
    metrics = [otelcol.processor.batch.metrics.input]
  }
}

// ── Batch (per signal) ──────────────────────────────────
otelcol.processor.batch "traces" {
  timeout         = "5s"
  send_batch_size = 512
  output { traces = [otelcol.exporter.otlp.tempo.input] }
}

otelcol.processor.batch "logs" {
  timeout         = "5s"
  send_batch_size = 512
  output { logs = [otelcol.exporter.loki.default.input] }
}

otelcol.processor.batch "metrics" {
  timeout         = "10s"
  send_batch_size = 1024
  output { metrics = [otelcol.exporter.prometheus.amp.input] }
}

// ── Logs → self-host Loki ────────────────────────────────
otelcol.exporter.loki "default" {
  forward_to = [loki.write.default.receiver]
}

loki.write "default" {
  endpoint {
    url = format("%s/loki/api/v1/push", env("LOKI_URL"))
  }
  external_labels = {
    cluster = "drawe-prod",
    env     = env("ALLOY_DEPLOY_ENV"),
  }
}

// ── Traces → self-host Tempo (OTLP) ──────────────────────
otelcol.exporter.otlp "tempo" {
  client {
    endpoint = env("TEMPO_OTLP_ENDPOINT")
    tls {
      insecure = true   // VPC 내부 통신, TLS 불필요
    }
  }
}

// ── Metrics → AMP (SigV4 signed RemoteWrite) ─────────────
otelcol.exporter.prometheus "amp" {
  forward_to = [prometheus.remote_write.amp.receiver]
}

prometheus.remote_write "amp" {
  endpoint {
    url = env("AMP_REMOTE_WRITE_URL")

    sigv4 {
      region = env("AWS_REGION")
      // service: aps (Amazon Managed Service for Prometheus)
    }

    queue_config {
      capacity           = 10000
      max_shards         = 50
      max_samples_per_send = 1500
    }
  }

  external_labels = {
    cluster = "drawe-prod",
  }
}
