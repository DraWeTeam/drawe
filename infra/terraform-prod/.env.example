# terraform-prod 실행 전 반드시 source 할 것:  set -a; . ./.env; set +a
#
# ★ 이 값들을 주입하지 않고 plan/apply 하면 terraform 이 random_password 를 새로 만들어
#   "암호를 바꾸겠다"는 diff 를 낸다. lifecycle ignore_changes 로 실제 반영은 막아뒀지만,
#   plan 을 깨끗하게 읽으려면 주입한 상태로 실행하는 게 맞다.
#   변수명은 variables.tf 와 정확히 일치해야 한다(이름이 틀리면 주입해도 무시된다).
CLOUDFLARE_API_TOKEN='api_token_here'
TF_VAR_db_password='db_password_here'
# variables.tf 의 변수명은 valkey_auth_token 이다(과거 valkey_password 로 잘못 적혀 있었음).
TF_VAR_valkey_auth_token='valkey_auth_token_here'
