          "expr": "sum by (step) (rate(drawe_llm_latency_seconds_count[5m])) / scalar(sum(rate(drawe_llm_latency_seconds_count{step=\"plan\"}[5m])))",
          "legendFormat": "{{step}}"
        }
      ]
    },
