              "mode": "normal"
            },
            "fillOpacity": 40
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (step) (rate(drawe_llm_latency_seconds_sum[5m]))",
          "legendFormat": "{{step}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "가이드 1건당 Grok 호출수 (step 별)",
      "description": "분모 = plan 호출수(설계상 /guide 1건당 1회, agent.py:257) → 자동계측 무의존. plan 은 1, coach 는 1 근처가 정상. coach 가 1 을 크게 넘으면 검증 탈락 재시도가 잦다는 뜻(validate.py 신호). ⚠️ step=\"select\" 가 없는 게 정상일 수 있다 — agent.py decide() 는 AGENT_LLM_SELECT(configmap 에서 \"1\"=ON) 이면서 동시에 stated_present 가 False 일 때만 _llm_select 를 부른다. stated_present = 유저가 물은 축이 맥락상 성립하는 경우 → 이때는 결정적 정책으로 대체된다. AMP 실측 2026-07-15: plan·coach 만 존재 = 지금까지 모든 요청이 축을 명시했다는 뜻. 계측 고장 아님.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
