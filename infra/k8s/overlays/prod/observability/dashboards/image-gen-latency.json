{
  "uid": "drawe-image-gen-latency",
  "title": "레퍼런스 이미지 생성 지연 (FastAPI/Bedrock) — P50/P95/P99",
  "description": "레퍼런스 생성(Stable Image 등) 기준. metric=drawe_image_gen_latency_seconds (guide/ml/generate.py generate() 초크포인트, OTEL histogram→OTLP→AMP). 생성용 버킷(1~120s, VLM보다 상단 높음)으로 diffusion 지연대 P95 정확. VLM 관찰·채팅 LLM 은 별도 대시보드(drawe-vlm-latency, drawe-chat-llm-latency).",
  "tags": ["drawe", "fastapi", "guide", "image-gen", "latency"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "이미지 생성 지연 — P50 · P95 · P99 (전체)",
      "description": "레퍼런스 이미지 생성(Bedrock Stable Image Core 등) 기준. drawe_image_gen_latency_seconds_bucket 히스토그램(명시 버킷 1,2,3,5,8,13,21,34,55,90,120s). 메트릭명이 이 서비스 전용이라 서비스 필터 불필요.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(drawe_image_gen_latency_seconds_bucket[5m])))",
          "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(drawe_image_gen_latency_seconds_bucket[5m])))",
          "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(drawe_image_gen_latency_seconds_bucket[5m])))",
          "legendFormat": "p99" }
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "P95 by provider (bedrock/gemini/bria)",
      "description": "생성 provider 별 P95. le·provider 로 분해 — prod=bedrock / dev=gemini 등 백엔드별 지연대 분리 관찰.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(drawe_image_gen_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p95" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "P95 by outcome (success/error)",
      "description": "outcome 별 P95. 타임아웃/에러가 지연대를 끌어올리는지 분리 관찰.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (outcome, le) (rate(drawe_image_gen_latency_seconds_bucket[5m])))",
          "legendFormat": "{{outcome}} p95" }
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "요청량 — 초당 생성 호출수 (by provider/outcome)",
      "description": "히스토그램 _count 의 rate. 분위수의 표본 규모·에러율 파악용.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider, outcome) (rate(drawe_image_gen_latency_seconds_count[5m]))",
          "legendFormat": "{{provider}} · {{outcome}}" }
      ]
    },
    {
      "id": 5, "type": "stat", "title": "P95 (현재, 전체)",
      "description": "지금 5분 창의 전체 P95. 생성은 VLM 관찰보다 훨씬 느리다(diffusion) — 임계 참고용(임의값): 30s 경고 / 60s 위험.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(drawe_image_gen_latency_seconds_bucket[5m])))" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "평균 생성시간 (참고 · 버킷 아님)",
      "description": "_sum/_count 평균. 분위수와 함께 보는 보조 지표.",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(drawe_image_gen_latency_seconds_sum[5m])) / sum(rate(drawe_image_gen_latency_seconds_count[5m]))",
          "legendFormat": "avg" }
      ]
    }
  ]
}
