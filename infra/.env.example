# ─────────────────────────────────────────────────────────────
# DraWe — 로컬 통합 스택 환경변수 (infra/docker-compose.local.yml)
#
# 사용:  cp .env.example .env   후 필요한 값(특히 API 키)을 채우세요.
#
# 참고
#   - compose 의 모든 변수에 기본값이 있어 .env 없이도 스택은 기동됩니다.
#     단 아래 외부 연동 키(LLM · OAuth · Pinecone)가 비어 있으면
#     해당 기능만 동작하지 않을 뿐, 컨테이너 기동 자체는 정상입니다.
#   - docker compose 는 실행 디렉터리(infra/)의 .env 를 자동 로드합니다.
#   - .env 는 .gitignore 로 커밋이 막혀 있습니다(이 .env.example 만 커밋됨).
# ─────────────────────────────────────────────────────────────

# ── DB / Redis (로컬 기본값 — 그대로 둬도 됨) ──
MYSQL_ROOT_PASSWORD=rootpass
DB_USERNAME=drawe_user
DB_PASSWORD=drawe_pass
REDIS_PASSWORD=valkey_pass

# ── 인증 ──
# compose 에 로컬용 기본 JWT_SECRET 이 내장돼 있어 비워둬도 동작합니다.
# 직접 지정하려면 base64 시크릿을 넣으세요:
# JWT_SECRET=
# (선택) 토큰 만료 — 앱 기본값: access 1h / refresh 7d
# JWT_ACCESS_EXPIRATION=3600000
# JWT_REFRESH_EXPIRATION=604800000

# ── LLM / 이미지 API 키 (해당 기능을 쓸 때만 채우기) ──
GROK_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
BRIA_API_KEY=
# (선택) 기본 LLM 공급자 — 앱 기본값: gemini
# LLM_DEFAULT_PROVIDER=gemini

# ── Pinecone (벡터 검색 — 백엔드·fastapi 양쪽에서 사용) ──
# 세 값 모두 application.properties 에서 기본값 없이 요구됩니다.
# HOST/INDEX 는 시크릿이 아니라 설정값 — 실제 값은 backend/.env.example 참고.
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX=drawe-images

# ── Google OAuth (로컬 로그인 테스트 시) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_OAUTH2_REDIRECT_URI=

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=my-secret-password

# Qdrant (dev 시드된 컬렉션). EMBEDDING_MODEL 은 그 차원과 반드시 일치
QDRANT_URL=https://4a5ec523-...us-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=<클라우드 키>
QDRANT_COLLECTION=reference_images_dev
EMBEDDING_MODEL=open_clip:ViT-L-14:openai   # Cloud dev=768-dim 기준

# ── 호스트 포트 override (포트 충돌 시에만 주석 해제) ──
# MYSQL_PORT=23306
# REDIS_PORT=26379
# BACKEND_PORT=28080
# FASTAPI_PORT=28000
